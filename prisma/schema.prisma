generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(uuid())
  name  String
  email String
  age   Int
  work String
}

model Product {
  id    String @id @default(uuid())
  name  String
  price Float
}